# LLMs
# Set according to https://ai.pydantic.dev/models/overview/
# OPENAI_API_KEY is required for moderation. If you set SKIP_MODERATION=true, you can remove the OpenAI key completely.
OPENAI_API_KEY=your-api-key
ANTHROPIC_API_KEY=your-api-key # Optional
GOOGLE_API_KEY=your-api-key # Optional
XAI_API_KEY=your-api-key # Optional
DEFAULT_MODEL_TEMP=0.6
DEFAULT_MODEL_NAME=gpt-4o-mini

# TTS
ELEVENLABS_TTS_API_KEY=your-api-key # Optional
GOOGLE_CLOUD_TTS_API_KEY=your-api-key
DEFAULT_TTS_PROVIDER=google # Can be google, elevanlabs

# DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=rpg-encounters
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
TEST_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}-test

# TELEMETRY
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key # Optional
LANGFUSE_SECRET_KEY=your-langfuse-secret-key # Optional
LANGFUSE_HOST=http://host.docker.internal:3000 # Optional

# System
ENVIRONMENT=local
SERVICE=backend
FRONTEND_URL=http://localhost:3001
ECR_REPO_URI=ecr-uri # Optional
GRPC_VERBOSITY=ERROR
DISABLE_RATE_LIMITING=false
AWS_REGION=eu-central-1 # Optional

# Local LAN
# LAN only login link base when ENVIRONMENT=local
LAN_PUBLIC_URL=http://192.168.1.50:3001 # Optional

# Email
SEND_EMAIL=false
LOG_MAGIC_LINK=true
SES_IDENTITY=noreply@your-domain.com # Optional

# Moderation
SKIP_MODERATION=false
OPEN_AI_MODERATION_THRESHOLD=0.5

# Session management
SESSION_SECRET_KEY=change-this-to-a-real-secret

# Cache
REDIS_URL=redis://redis:6379/0
BILLING_CACHE_TTL_SECONDS=3600
BILLING_FLUSH_INTERVAL_SECONDS=60

# Billing 
BILLING_IGNORE_BALANCE_CHECK=false

# HTTPS Configuration
USE_HTTPS=false

# Transcription
TRANSCRIPTION_POOL_SIZE=2
