# LLMs
OPENAI_API_KEY=your-openai-api-key-here
DEFAULT_MODEL_TEMP=0.6
DEFAULT_MODEL_NAME=gpt-4o-mini

# TTS
ELEVENLABS_TTS_API_KEY=your-elevenlabs-api-key-here # Optional
GOOGLE_CLOUD_TTS_API_KEY=your-google-cloud-tts-api-key-here
DEFAULT_TTS_PROVIDER=google

# DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=rpg-encounters
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}
TEST_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}-test

# TELEMETRY
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here # Optional
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here # Optional
LANGFUSE_HOST=http://host.docker.internal:3000 # Optional

# System
ENVIRONMENT=local
SERVICE=backend
FRONTEND_URL=http://localhost:3001
ECR_REPO_URI=ecr-uri-prd # Optional
GRPC_VERBOSITY=ERROR
DISABLE_RATE_LIMITING=false
AWS_REGION=eu-central-1 # Optional

# Extensions
EXTENSIONS=my_package.extensions:register,another_pkg.hooks:register # Optional

# Email
SEND_EMAIL=false
LOG_MAGIC_LINK=true
SES_IDENTITY=noreply@your-domain.com # Optional

# Moderation
SKIP_MODERATION=false
OPEN_AI_MODERATION_THRESHOLD=0.5

# Session management
SESSION_SECRET_KEY=change-this-to-a-real-secret

# Cache
REDIS_URL=redis://redis:6379/0
BILLING_CACHE_TTL_SECONDS=3600
BILLING_FLUSH_INTERVAL_SECONDS=60

# Billing 
BILLING_IGNORE_BALANCE_CHECK=false

# HTTPS Configuration
USE_HTTPS=false

# Transcription
TRANSCRIPTION_POOL_SIZE=2
