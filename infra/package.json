{
  "name": "infra",
  "version": "1.0.0",
  "main": "main.js",
  "types": "main.ts",
  "private": true,
  "scripts": {
    "get": "cdktf get",
    "build": "tsc",
    "synth": "cdktf synth",
    "compile": "tsc --pretty",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "deploy": "AWS_PROFILE=rpg-admin cdktf deploy",
    "destroy": "AWS_PROFILE=rpg-admin cdktf destroy",
    "watch": "tsc -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "upgrade": "npm i cdktf@latest cdktf-cli@latest",
    "upgrade:next": "npm i cdktf@next cdktf-cli@next"
  },
  "engines": {
    "node": ">=20.9"
  },
  "dependencies": {
    "@cdktf/provider-aws": "^21.10.0",
    "cdktf": "^0.21.0",
    "constructs": "^10.4.2",
    "dotenv": "^17.3.1",
    "mime-types": "^3.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.3.1",
    "jest": "^30.1.3",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
