{
  "name": "rpg-encounters-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.14.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "generate:api-types": "UV_CACHE_DIR=${UV_CACHE_DIR:-./.uv-cache} uv --project ../backend run python ../backend/scripts/generate_backend_types.py | openapi-typescript --output src/types/_generated/openapi.d.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "e2e": "playwright test --grep-invert @audio && npm run e2e:audio:all",
    "e2e:chromium": "playwright test --project=chromium",
    "e2e:webkit": "playwright test --project=webkit",
    "e2e:headed": "playwright test --headed",
    "e2e:audio:all": "ENCOUNTERS_AUDIO_TEST=1 playwright test --config playwright.audio.config.js --grep @audio",
    "e2e:player-mobile:all": "ENCOUNTERS_AUDIO_TEST=1 playwright test --config playwright.audio.config.js --grep \"^PLAYER-\""
  },
  "dependencies": {
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.45.1",
    "@vue-flow/minimap": "^1.5.3",
    "marked": "^16.2.1",
    "pinia": "^3.0.3",
    "serialize-error": "^12.0.0",
    "uuid": "^11.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.3.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.17.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "3.6.2",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitest": "^2.1.8",
    "vue-tsc": "^3.2.5"
  }
}
